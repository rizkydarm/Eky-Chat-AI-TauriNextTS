{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-nextjs-template",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "beforeDevCommand": "TAURI_ENV=true bun dev:next",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "TAURI_ENV=true bun build:next",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Eky Chat AI",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
